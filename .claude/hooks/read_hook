#!/bin/bash
INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')

if echo "$FILE_PATH" | grep -qE '(^|/)(\.env(\.[^/]*)?|\.secret|credentials\.json|\.pem|\.key|id_rsa)$'; then
  jq -n --arg reason "Blocked: reading sensitive file '$FILE_PATH' is not allowed" \
    '{"continue": false, "stopReason": $reason}'
  exit 0
fi
